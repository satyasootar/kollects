{
  "name": "@repo/database",
  "version": "1.0.0",
  "main": "./index.ts",
  "types": "./index.ts",
  "exports": {
    ".": "./index.ts",
    "./schema": "./schema.ts",
    "./schemas/*": "./schemas/*.ts",
    "./schemas/dynamic-validator": "./schemas/dynamic-validator.ts",
    "./models/*": "./models/*.ts",
    "./constants": "./constants/index.ts",
    "./constants/*": "./constants/*.ts",
    "./types": "./types/index.ts",
    "./types/*": "./types/*.ts",
    "./utils": "./utils/index.ts",
    "./utils/*": "./utils/*.ts"
  },
  "scripts": {
    "db:migrate": "dotenv -- drizzle-kit migrate",
    "db:generate": "dotenv -- drizzle-kit generate",
    "dev": "dotenv -- drizzle-kit studio",
    "seed": "dotenv -- tsx seed.ts"
  },
  "devDependencies": {
    "@repo/eslint-config": "workspace:*",
    "@repo/typescript-config": "workspace:*",
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.16.0",
    "@types/safe-regex": "^1.1.6",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.8",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.16.3",
    "safe-regex": "^2.1.1",
    "zod": "^4.3.5"
  }
}
